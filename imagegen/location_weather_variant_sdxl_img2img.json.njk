{
  "1": {
    "inputs": {
      "ckpt_name": "{{ image.checkpoint | json }}"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "2": {
    "inputs": {
      "image": "{{ image.sourceFilename | json }}",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Source Location Image"
    }
  },
  "3": {
    "inputs": {
      "text": "{{ image.prompt | json }}",
      "clip": [
        "1",
        1
      ]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "4": {
    "inputs": {
      "text": "{{ image.negativePrompt | json }}",
      "clip": [
        "1",
        1
      ]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "5": {
    "inputs": {
      "pixels": [
        "2",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "class_type": "VAEEncode",
    "_meta": {
      "title": "Encode Source Image"
    }
  },
  "6": {
    "inputs": {
      "seed": {{ image.seed }},
      "steps": {{ image.steps }},
      "cfg": {{ image.cfg }},
      "sampler_name": "{{ image.sampler | json }}",
      "scheduler": "{{ image.scheduler | json }}",
      "denoise": {{ image.denoise }},
      "model": [
        "1",
        0
      ],
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "5",
        0
      ]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "Weather and Lighting Edit"
    }
  },
  "7": {
    "inputs": {
      "samples": [
        "6",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "Decode Edited Image"
    }
  },
  "8": {
    "inputs": {
      "filename_prefix": "airpg_location_variant",
      "images": [
        "7",
        0
      ]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Location Variant"
    }
  }
}
