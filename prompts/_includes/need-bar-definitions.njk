<needBarDefinitions>
  {% for bar in needBarDefinitions %}
  <needBar>
    <id>{{ bar.id | default('unknown', true) }}</id>
    <name>{{ bar.name }}</name>
    <description>{{ bar.description }}</description>
    <increases>
      <!-- These things increase the need bar. The amount of increase is determined by the tag (small, medium, large, fill) -->
      <small>
        {% for item in bar.increases.small %}<trigger>{{ item }}</trigger>{% endfor %}
      </small>
      <medium>
        {% for item in bar.increases.medium %}<trigger>{{ item }}</trigger>{% endfor %}
      </medium>
      <large>
        {% for item in bar.increases.large %}<trigger>{{ item }}</trigger>{% endfor %}
      </large>
      <fill>
        {% for item in bar.increases.fill %}<trigger>{{ item }}</trigger>{% endfor %}
      </fill>
    </increases>
    <decreases>
      <!-- These things decrease the need bar. The amount of decrease is determined by the tag (small, medium, large, empty) -->
      <small>
        {% for item in bar.decreases.small %}<trigger>{{ item }}</trigger>{% endfor %}
      </small>
      <medium>
        {% for item in bar.decreases.medium %}<trigger>{{ item }}</trigger>{% endfor %}
      </medium>
      <large>
        {% for item in bar.decreases.large %}<trigger>{{ item }}</trigger>{% endfor %}
      </large>
      <empty>
        {% for item in bar.decreases.empty %}<trigger>{{ item }}</trigger>{% endfor %}
      </empty>
    </decreases>
  </needBar>
  {% endfor %}
</needBarDefinitions>